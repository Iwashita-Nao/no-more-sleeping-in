# Normalize line endings to LF for all text files
* text=auto eol=lf

# Explicitly declare text files
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.svg   text eol=lf
*.ps1   text eol=lf

# Binary files — never modify line endings
*.png   binary
*.jpg   binary
*.ico   binary
*.woff2 binary
